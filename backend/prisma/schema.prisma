generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameSessionStatus {
  lobby
  active
  finished
  cancelled
}

enum GameSessionVisibility {
  solo
  public
  invite_only
}

enum GameSessionPlayerKind {
  human
  bot
}

model User {
  id                    Int                 @id @default(autoincrement())
  nickname              String              @unique @db.VarChar(32)
  name                  String              @db.VarChar(80)
  isBot                 Boolean             @default(false) @map("is_bot")
  info                  String?             @db.Text
  avatarPath            String?             @map("avatar_path") @db.Text
  nicknameColor         String?             @map("nickname_color") @db.VarChar(7)
  pushDisableAllMentions Boolean            @default(false) @map("push_disable_all_mentions")
  donationBadgeUntil    DateTime?           @map("donation_badge_until") @db.Timestamptz(3)
  passwordHash          String              @map("password_hash")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdInvites        Invite[]            @relation("InviteCreatedBy")
  usedInvites           Invite[]            @relation("InviteUsedBy")
  createdNodes          Node[]              @relation("NodeCreatedBy")
  roomMemberships       RoomUser[]
  sentMessages          Message[]           @relation("MessageSender")
  sessions              Session[]
  reactions             MessageReaction[]
  pushSubscriptions     PushSubscription[]
  createdGameSessions   GameSession[]       @relation("GameSessionCreatedBy")
  gameSessionPlayers    GameSessionPlayer[]
  ownedContacts         UserContact[]       @relation("ContactOwner")
  contactOf             UserContact[]       @relation("ContactTarget")

  @@index([name], map: "users_name_idx")
  @@map("users")
}

model Invite {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(64)
  createdById Int?      @map("created_by")
  createdBy   User?     @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  usedById    Int?      @map("used_by")
  usedBy      User?     @relation("InviteUsedBy", fields: [usedById], references: [id], onDelete: SetNull)
  usedAt      DateTime? @map("used_at") @db.Timestamptz(3)
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(3)
  rooms       InviteRoom[]

  @@map("invites")
}

model Node {
  id            Int      @id @default(autoincrement())
  parentId      Int?     @map("parent_id")
  parent        Node?    @relation("NodeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children      Node[]   @relation("NodeTree")
  type          String   @db.VarChar(64)
  component     String?  @db.VarChar(160)
  clientScript  String?  @map("client_script") @db.VarChar(160)
  serverScript  String?  @map("server_script") @db.VarChar(160)
  data          Json     @default("{}") @db.JsonB
  createdById   Int?     @map("created_by")
  createdBy     User?    @relation("NodeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  room          Room?
  message       Message?
  pinnedInRooms Room[]   @relation("RoomPinnedNode")

  @@index([parentId], map: "nodes_parent_idx")
  @@index([type], map: "nodes_type_idx")
  @@index([parentId, type, id(sort: Desc)], map: "nodes_parent_type_id_desc_idx")
  @@map("nodes")
}

model Room {
  id              Int      @id
  node            Node     @relation(fields: [id], references: [id], onDelete: Cascade)
  kind            String   @db.VarChar(64)
  title           String?  @db.Text
  visibility      String   @default("public") @db.VarChar(16)
  commentsEnabled Boolean  @default(true) @map("comments_enabled")
  avatarPath      String?  @map("avatar_path") @db.Text
  postOnlyByAdmin Boolean  @default(false) @map("post_only_by_admin")
  pinnedNodeId    Int?     @map("pinned_node_id")
  pinnedNode      Node?    @relation("RoomPinnedNode", fields: [pinnedNodeId], references: [id], onDelete: SetNull)
  roomUsers       RoomUser[]
  gameSessions    GameSession[]
  inviteRooms     InviteRoom[]

  @@index([kind], map: "rooms_kind_idx")
  @@index([pinnedNodeId], map: "rooms_pinned_node_idx")
  @@map("rooms")
}

model RoomUser {
  roomId   Int      @map("room_id")
  userId   Int      @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz(3)
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([userId], map: "rooms_users_user_idx")
  @@map("rooms_users")
}

model Message {
  id           Int               @id
  node         Node              @relation(fields: [id], references: [id], onDelete: Cascade)
  senderId     Int?              @map("sender_id")
  sender       User?             @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  kind         String            @db.VarChar(64)
  rawText      String            @map("raw_text")
  renderedHtml String            @map("rendered_html")
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  reactions    MessageReaction[]

  @@index([senderId], map: "messages_sender_idx")
  @@index([createdAt(sort: Desc)], map: "messages_created_desc_idx")
  @@map("messages")
}

model MessageReaction {
  id        Int      @id @default(autoincrement())
  messageId Int      @map("message_id")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reaction  String   @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([messageId, userId], map: "message_reactions_unique")
  @@index([messageId, reaction], map: "message_reactions_message_idx")
  @@map("message_reactions")
}

model GameSession {
  id           Int                   @id @default(autoincrement())
  roomId       Int                   @map("room_id")
  room         Room                  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  moduleKey    String                @map("module_key") @db.VarChar(64)
  status       GameSessionStatus
  visibility   GameSessionVisibility
  createdById  Int?                  @map("created_by")
  createdBy    User?                 @relation("GameSessionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  startedAt    DateTime?             @map("started_at") @db.Timestamptz(3)
  finishedAt   DateTime?             @map("finished_at") @db.Timestamptz(3)
  settingsJson Json                  @map("settings_json")
  stateJson    Json                  @map("state_json")
  players      GameSessionPlayer[]

  @@index([roomId], map: "game_sessions_room_idx")
  @@index([moduleKey, status], map: "game_sessions_module_status_idx")
  @@map("game_sessions")
}

model GameSessionPlayer {
  sessionId Int                   @map("session_id")
  userId    Int                   @map("user_id")
  seat      Int
  kind      GameSessionPlayerKind
  joinedAt  DateTime              @default(now()) @map("joined_at") @db.Timestamptz(3)
  isReady   Boolean               @default(true) @map("is_ready")
  session   GameSession           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  @@unique([sessionId, seat], map: "game_session_players_session_seat_key")
  @@index([userId], map: "game_session_players_user_idx")
  @@map("game_session_players")
}

model Session {
  id        String   @id @db.Uuid
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)
  ip        String?  @db.VarChar(64)
  userAgent String?  @map("user_agent")

  @@index([expiresAt], map: "sessions_expires_idx")
  @@map("sessions")
}

model PushSubscription {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String   @unique @db.Text
  p256dh     String   @db.Text
  auth       String   @db.Text
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(3)

  @@index([userId], map: "push_subscriptions_user_idx")
  @@map("push_subscriptions")
}

model InviteRoom {
  inviteId Int    @map("invite_id")
  roomId   Int    @map("room_id")
  invite   Invite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  room     Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([inviteId, roomId])
  @@index([roomId])
  @@map("invites_rooms")
}

model UserContact {
  ownerId   Int      @map("owner_id")
  contactId Int      @map("contact_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  owner     User     @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  contact   User     @relation("ContactTarget", fields: [contactId], references: [id], onDelete: Cascade)

  @@id([ownerId, contactId])
  @@index([contactId])
  @@map("users_contacts")
}
