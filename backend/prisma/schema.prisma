generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomKind {
  group
  direct
  game
}

enum MessageKind {
  text
  system
  scriptable
}

enum ScriptExecutionMode {
  client
  client_server
  client_runner
}

enum GameSessionStatus {
  lobby
  active
  finished
  cancelled
}

enum GameSessionVisibility {
  solo
  public
  invite_only
}

enum GameSessionPlayerKind {
  human
  bot
}

model User {
  id                 Int               @id @default(autoincrement())
  nickname           String            @unique @db.VarChar(32)
  name               String            @db.VarChar(80)
  isBot              Boolean           @default(false) @map("is_bot")
  info               String?           @db.Text
  nicknameColor      String?           @map("nickname_color") @db.VarChar(7)
  pushDisableAllMentions Boolean       @default(false) @map("push_disable_all_mentions")
  donationBadgeUntil DateTime?         @map("donation_badge_until") @db.Timestamptz(3)
  passwordHash       String            @map("password_hash")
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdInvites     Invite[]          @relation("InviteCreatedBy")
  usedInvites        Invite[]          @relation("InviteUsedBy")
  createdRooms       Room[]            @relation("RoomCreatedBy")
  roomMemberships    RoomUser[]
  sentMessages       Message[]         @relation("MessageSender")
  sessions           Session[]
  reactions          MessageReaction[]
  pushSubscriptions  PushSubscription[]
  createdGameSessions GameSession[]     @relation("GameSessionCreatedBy")
  gameSessionPlayers GameSessionPlayer[]

  @@index([name], map: "users_name_idx")
  @@map("users")
}

model Invite {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(64)
  createdById Int?      @map("created_by")
  createdBy   User?     @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  usedById    Int?      @map("used_by")
  usedBy      User?     @relation("InviteUsedBy", fields: [usedById], references: [id], onDelete: SetNull)
  usedAt      DateTime? @map("used_at") @db.Timestamptz(3)
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(3)

  @@map("invites")
}

model Room {
  id              Int                  @id @default(autoincrement())
  kind            RoomKind
  title           String?
  createdById     Int?                 @map("created_by")
  createdBy       User?                @relation("RoomCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  pinnedMessageId Int?                 @map("pinned_message_id")
  pinnedMessage   Message?             @relation("RoomPinnedMessage", fields: [pinnedMessageId], references: [id], onDelete: SetNull)
  scriptId        String?              @map("script_id") @db.VarChar(128)
  scriptRevision  Int                  @default(0) @map("script_revision")
  scriptConfigJson Json                @default("{}") @map("script_config_json")
  scriptStateJson Json                 @default("{}") @map("script_state_json")
  scriptMode      ScriptExecutionMode? @map("script_mode")
  roomUsers       RoomUser[]
  messages        Message[]            @relation("RoomMessages")
  gameSessions    GameSession[]

  @@index([kind], map: "rooms_kind_idx")
  @@index([pinnedMessageId], map: "rooms_pinned_message_idx")
  @@index([scriptId], map: "rooms_script_id_idx")
  @@map("rooms")
}

model RoomUser {
  roomId   Int      @map("room_id")
  userId   Int      @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz(3)
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([userId], map: "rooms_users_user_idx")
  @@map("rooms_users")
}

model GameSession {
  id          Int                   @id @default(autoincrement())
  roomId      Int                   @map("room_id")
  room        Room                  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  moduleKey   String                @map("module_key") @db.VarChar(64)
  status      GameSessionStatus
  visibility  GameSessionVisibility
  createdById Int?                  @map("created_by")
  createdBy   User?                 @relation("GameSessionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  startedAt   DateTime?             @map("started_at") @db.Timestamptz(3)
  finishedAt  DateTime?             @map("finished_at") @db.Timestamptz(3)
  settingsJson Json                 @map("settings_json")
  stateJson   Json                  @map("state_json")
  players     GameSessionPlayer[]

  @@index([roomId], map: "game_sessions_room_idx")
  @@index([moduleKey, status], map: "game_sessions_module_status_idx")
  @@map("game_sessions")
}

model GameSessionPlayer {
  sessionId Int                   @map("session_id")
  userId    Int                   @map("user_id")
  seat      Int
  kind      GameSessionPlayerKind
  joinedAt  DateTime              @default(now()) @map("joined_at") @db.Timestamptz(3)
  isReady   Boolean               @default(true) @map("is_ready")
  session   GameSession           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  @@unique([sessionId, seat], map: "game_session_players_session_seat_key")
  @@index([userId], map: "game_session_players_user_idx")
  @@map("game_session_players")
}

model Message {
  id               Int                  @id @default(autoincrement())
  roomId           Int                  @map("room_id")
  room             Room                 @relation("RoomMessages", fields: [roomId], references: [id], onDelete: Cascade)
  senderId         Int?                 @map("sender_id")
  sender           User?                @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  kind             MessageKind          @default(text)
  rawText          String               @map("raw_text")
  renderedHtml     String               @map("rendered_html")
  scriptId         String?              @map("script_id") @db.VarChar(128)
  scriptRevision   Int                  @default(0) @map("script_revision")
  scriptConfigJson Json                 @default("{}") @map("script_config_json")
  scriptStateJson  Json                 @default("{}") @map("script_state_json")
  scriptMode       ScriptExecutionMode? @map("script_mode")
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  reactions        MessageReaction[]
  pinnedInRooms    Room[]               @relation("RoomPinnedMessage")

  @@index([roomId, createdAt(sort: Desc)], map: "messages_room_created_idx")
  @@index([scriptId], map: "messages_script_id_idx")
  @@map("messages")
}

model MessageReaction {
  id        Int      @id @default(autoincrement())
  messageId Int      @map("message_id")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reaction  String   @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([messageId, userId], map: "message_reactions_unique")
  @@index([messageId, reaction], map: "message_reactions_message_idx")
  @@map("message_reactions")
}

model Session {
  id        String   @id @db.Uuid
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)
  ip        String?  @db.VarChar(64)
  userAgent String?  @map("user_agent")

  @@index([expiresAt], map: "sessions_expires_idx")
  @@map("sessions")
}

model PushSubscription {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String   @unique @db.Text
  p256dh     String   @db.Text
  auth       String   @db.Text
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(3)

  @@index([userId], map: "push_subscriptions_user_idx")
  @@map("push_subscriptions")
}
