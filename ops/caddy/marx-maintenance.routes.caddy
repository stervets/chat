@backend {
    path /ws /ws/* /push /push/* /upload/image /upload/media /uploads /uploads/*
}

handle @backend {
    respond "Maintenance mode" 503
}

handle {
    root * /home/lisov/projects/chat/ops/maintenance
    header Cache-Control "no-store, no-cache, must-revalidate"
    rewrite * /index.html
    file_server
}
